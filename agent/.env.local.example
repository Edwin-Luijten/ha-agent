# Copy to .env.local and fill in before running uvicorn locally.
# In production (as an HA add-on) none of these are needed — Supervisor
# injects SUPERVISOR_TOKEN, the rest come from the add-on options.

# Long-lived access token from HA (Profile → Security → Long-lived tokens)
SUPERVISOR_TOKEN=

# Gemini key from https://aistudio.google.com/apikey
# (enable billing — free tier is too tight for tool-heavy turns)
GOOGLE_API_KEY=

# Where your HA is reachable from this machine
HA_URL=https://homeassistant.example.com
HA_WS_URL=wss://homeassistant.example.com/api/websocket

# Local paths (outside the add-on's /data)
DATA_DIR=/tmp/ha-agent-data
UI_DIST_DIR=./ui/dist

# Optional overrides
# MODEL=gemini-flash-latest
# LANGUAGE=nl
# LOG_LEVEL=info
# RATE_LIMIT_PER_MIN=20
